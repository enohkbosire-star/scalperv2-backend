{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach to Chrome",
            "port": 9222,
            "request": "attach",
            "type": "chrome",
            "webRoot": "${workspaceFolder}"
        },
        {
            "type": "java",
            "request": "attach",
            "name": "Attach by Process ID",
            "processId": "${command:PickJavaProcess}"
        },
        {
            "type": "java",
            "name": "Run Fxausd",
            "request": "launch",
            "mainClass": "com.mycompany.fxausd.Fxausd",
            "projectName": "Fxausd",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        }
    ]
}